{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["dist/**", ".astro/**", "node_modules/**"],
  "overrides": [
    {
      "files": ["**/*.astro"],
      "rules": { "import/no-unassigned-import": "off" }
    }
  ],
  "plugins": ["typescript", "unicorn", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  }
}
