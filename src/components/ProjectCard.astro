---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"project">;
  index: number;
}

const { project, index } = Astro.props;
const backgrounds = ["bg-chart-5/35", "bg-secondary/45", "bg-chart-4/30", "bg-primary/30", "bg-accent/55"];
---

<a class="group block no-underline" href={`/project/${project.id}`}>
  <div class="relative overflow-hidden rounded-[16px] border border-white/80 bg-card p-2 shadow-[0_24px_55px_-42px_oklch(0.35_0.04_20/.48),0_2px_8px_-5px_oklch(0.35_0.04_20/.28),inset_0_1px_0_white] transition-[transform,box-shadow] duration-300 group-hover:-translate-y-1 group-hover:shadow-[0_30px_65px_-42px_oklch(0.35_0.04_20/.58),0_4px_12px_-6px_oklch(0.35_0.04_20/.28),inset_0_1px_0_white]">
    <div class:list={["relative grid min-h-104 place-items-center overflow-hidden rounded-[11px] border max-[700px]:min-h-80", backgrounds[index % backgrounds.length]]}>
      <span class="absolute left-3 top-3 rounded-[6px] border border-white/75 bg-card/80 px-2 py-1 font-mono text-[10px] text-muted-foreground backdrop-blur">0{index + 1}</span>
      <Image class="max-h-84 w-[min(78%,39rem)] object-contain drop-shadow-[0_20px_18px_oklch(0.3_0.03_20/.22)] [image-rendering:pixelated] transition-transform duration-300 group-hover:scale-[1.035]" src={project.data.cover} alt={`Preview of ${project.data.title}`} widths={[480, 800]} sizes="(max-width: 700px) 100vw, 50vw" />
      <span class="absolute right-3 top-3 grid size-8 place-items-center rounded-[7px] border border-white/75 bg-card/80 text-xs backdrop-blur" aria-hidden="true">↗</span>
    </div>
  </div>
  <div class="flex items-start justify-between gap-4 px-1 pb-4 pt-4 max-[700px]:block">
    <div><h3 class="m-0 text-xl tracking-[-.02em]">{project.data.title}</h3><p class="mt-2 max-w-xl text-sm leading-6 text-muted-foreground">{project.data.description}</p></div>
    <span class="mt-1 shrink-0 rounded-[5px] border bg-card px-2 py-1 font-mono text-[9px] uppercase text-muted-foreground max-[700px]:mt-3 max-[700px]:inline-block">{project.data.status}</span>
  </div>
</a>
