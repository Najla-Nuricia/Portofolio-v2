---
const items = [
  { href: "/", label: "Home", icon: "home" },
  { href: "/#work", label: "Work", icon: "work" },
  { href: "/#projects", label: "Projects", icon: "grid" },
  { href: "/#contact", label: "Contact", icon: "mail" },
];
---

<aside class="fixed bottom-[max(.75rem,env(safe-area-inset-bottom))] left-1/2 z-50 -translate-x-1/2 md:bottom-auto md:left-4 md:top-1/2 md:-translate-x-0 md:-translate-y-1/2" aria-label="Portfolio navigation">
  <details class="group rounded-[14px] md:hidden">
    <nav class="mb-2 hidden items-center gap-1 rounded-[14px] border border-white/80 bg-card/92 p-1.5 shadow-lg backdrop-blur-xl group-open:flex">
      {items.map((item) => (
        <a class="grid size-11 place-items-center rounded-[9px] text-muted-foreground no-underline transition-colors hover:bg-muted hover:text-foreground focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring" href={item.href} aria-label={item.label}>
          {item.icon === "home" && <svg aria-hidden="true" viewBox="0 0 24 24" class="size-4.5" fill="none" stroke="currentColor" stroke-width="1.7"><path d="m4 10 8-6 8 6v9a1 1 0 0 1-1 1h-5v-6h-4v6H5a1 1 0 0 1-1-1v-9Z" /></svg>}
          {item.icon === "work" && <svg aria-hidden="true" viewBox="0 0 24 24" class="size-4.5" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M8 7V5.8A1.8 1.8 0 0 1 9.8 4h4.4A1.8 1.8 0 0 1 16 5.8V7M4 8.5h16v10.2A1.3 1.3 0 0 1 18.7 20H5.3A1.3 1.3 0 0 1 4 18.7V8.5Z"/><path d="M4 12h16M10 12v1.5h4V12"/></svg>}
          {item.icon === "grid" && <svg aria-hidden="true" viewBox="0 0 24 24" class="size-4.5" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="4" y="4" width="6" height="6" rx="1"/><rect x="14" y="4" width="6" height="6" rx="1"/><rect x="4" y="14" width="6" height="6" rx="1"/><rect x="14" y="14" width="6" height="6" rx="1"/></svg>}
          {item.icon === "mail" && <svg aria-hidden="true" viewBox="0 0 24 24" class="size-4.5" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3.5" y="5.5" width="17" height="13" rx="2"/><path d="m5 8 7 5 7-5"/></svg>}
        </a>
      ))}
    </nav>
    <summary class="mx-auto grid size-12 cursor-pointer list-none place-items-center rounded-[13px] border border-white/80 bg-card/92 text-muted-foreground shadow-lg backdrop-blur-xl marker:hidden focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring [&::-webkit-details-marker]:hidden">
      <svg aria-hidden="true" viewBox="0 0 24 24" class="size-5 group-open:hidden" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M5 7h14M5 12h14M5 17h14" /></svg>
      <svg aria-hidden="true" viewBox="0 0 24 24" class="hidden size-5 group-open:block" fill="none" stroke="currentColor" stroke-width="1.7"><path d="m7 7 10 10M17 7 7 17" /></svg>
      <span class="sr-only">Toggle navigation</span>
    </summary>
  </details>

  <nav class="group/rail hidden w-14 flex-col items-stretch gap-1 overflow-hidden rounded-[14px] border border-white/80 bg-card/88 p-1.5 shadow-[0_18px_50px_-24px_oklch(0.35_0.04_20/.45),inset_0_1px_0_white] backdrop-blur-xl transition-[width] duration-200 hover:w-36 focus-within:w-36 md:flex">
    {items.map((item) => (
      <a class="flex h-11 w-full shrink-0 items-center rounded-[9px] text-muted-foreground no-underline transition-colors hover:bg-muted hover:text-foreground focus-visible:bg-muted focus-visible:text-foreground focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring" href={item.href} aria-label={item.label}>
        <span class="grid size-11 shrink-0 place-items-center">
          {item.icon === "home" && <svg aria-hidden="true" viewBox="0 0 24 24" class="size-4.5" fill="none" stroke="currentColor" stroke-width="1.7"><path d="m4 10 8-6 8 6v9a1 1 0 0 1-1 1h-5v-6h-4v6H5a1 1 0 0 1-1-1v-9Z" /></svg>}
          {item.icon === "work" && <svg aria-hidden="true" viewBox="0 0 24 24" class="size-4.5" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M8 7V5.8A1.8 1.8 0 0 1 9.8 4h4.4A1.8 1.8 0 0 1 16 5.8V7M4 8.5h16v10.2A1.3 1.3 0 0 1 18.7 20H5.3A1.3 1.3 0 0 1 4 18.7V8.5Z"/><path d="M4 12h16M10 12v1.5h4V12"/></svg>}
          {item.icon === "grid" && <svg aria-hidden="true" viewBox="0 0 24 24" class="size-4.5" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="4" y="4" width="6" height="6" rx="1"/><rect x="14" y="4" width="6" height="6" rx="1"/><rect x="4" y="14" width="6" height="6" rx="1"/><rect x="14" y="14" width="6" height="6" rx="1"/></svg>}
          {item.icon === "mail" && <svg aria-hidden="true" viewBox="0 0 24 24" class="size-4.5" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3.5" y="5.5" width="17" height="13" rx="2"/><path d="m5 8 7 5 7-5"/></svg>}
        </span>
        <span class="whitespace-nowrap pr-4 text-xs font-medium opacity-0 transition-opacity duration-150 group-hover/rail:opacity-100 group-focus-within/rail:opacity-100">{item.label}</span>
      </a>
    ))}
  </nav>
</aside>
