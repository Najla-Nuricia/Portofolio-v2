---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Something went wrong — Najla Portfolio" description="The Portfolio encountered an unexpected error." noindex>
  <main id="main-content" class="grid min-h-screen place-items-center p-6 text-center">
    <div><span class="text-8xl text-primary">Oh!</span><h1 class="mt-6 text-5xl tracking-[-.05em]">A pixel fell out of place.</h1><p class="mx-auto mt-4 max-w-md text-muted-foreground">Please try again. If the problem continues, come back a little later.</p><a class="button mt-8" href="/">Return home</a></div>
  </main>
</BaseLayout>
